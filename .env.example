# PostgreSQL connection string (Prisma driver adapter)
DATABASE_URL="postgresql://user:password@localhost:5432/soc_dashboard?schema=public"

# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook signing secret (Dashboard → Webhooks → your endpoint)
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Clerk redirect routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
